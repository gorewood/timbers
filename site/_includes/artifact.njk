---
layout: base.njk
---
<article class="artifact shell reading-shell">
  <header class="artifact-heading">
    <a class="back-link" href="{{ ('/' + collection_route + '/') | siteUrl }}">← {{ collection_label }}</a>
    <p class="eyebrow">{% if artifact_kind == "native" %}Native artifact{% else %}Generated report{% endif %}</p>
    <h1>{{ title or page.fileSlug }}</h1>
    <dl class="artifact-byline">
      {% if date %}<div><dt>Published</dt><dd><time datetime="{{ date | isoDate }}">{{ date | displayDate }}</time></dd></div>{% endif %}
      {% if status %}<div><dt>Status</dt><dd>{{ status }}</dd></div>{% endif %}
      {% if source %}<div><dt>Source</dt><dd>{{ source }}</dd></div>{% endif %}
    </dl>
    {% if summary %}<p class="lede">{{ summary }}</p>{% endif %}
  </header>
  <div class="prose">
    {{ content | safe }}
  </div>
</article>
