# Go .gitignore
# Allowlist-style: ignore everything, then explicitly allow Go files
# Based on: https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore

# =============================================================================
# COMMON PATTERNS (all languages)
# =============================================================================

# Environment
.env
.env.local
.env.*.local
.envrc

# OS files
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# =============================================================================
# GO-SPECIFIC (Allowlist approach)
# =============================================================================

# Ignore everything
*

# But not these files...
!/.gitignore

# Go source and modules
!*.go
!go.sum
!go.mod

# Embedded template files (used by go:embed)
!internal/draft/templates/*.md

# Documentation
!README.md
!LICENSE
!CLAUDE.md
!CHANGELOG.md
!CONTRIBUTING.md
!AGENTS.md
!.claudeignore
!docs/
!docs/**

# Claude/Codex team rules
!.claude/
!.claude/rules/
!.claude/rules/*.md

# Build system
!justfile
!Makefile

# Config files
!.golangci.yml
!.mise.toml
!.env.example
!.envrc.example
!.goreleaser.yaml

# CI/CD
!.github/
!.github/**

# Install script
!install.sh

# Timbers per-repo skip config (shared — gate reads it in every clone/CI)
!.timbersignore

# Timbers ledger entries
!.timbers/
!.timbers/**

# Beads issue tracking
!.beads/
!.beads/**

# Eleventy publishing site - source files only
!site/
!site/**
site/node_modules/
site/.generated/
site/_site/
site/public/
site/resources/
site/.hugo_build.lock

# Allow directories to be traversed
!*/

# Generated site directories stay ignored after the traversal allowlist above.
.worktrees/
site/node_modules/**
site/.generated/**
site/_site/**
site/public/**
site/resources/**
site/.hugo_build.lock

# Dolt database files (added by bd init)
.dolt/
*.db

# Beads / Dolt files (added by bd init)
.beads-credential-key
